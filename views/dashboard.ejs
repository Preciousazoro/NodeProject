<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

  <% if (success?.length) { %>
    <div class="toast success"><%= success[0] %></div>
  <% } %>

  <% if (error?.length) { %>
    <div class="toast error"><%= error[0] %></div>
  <% } %>

  <nav class="navbar">
    <h1>Dashboard</h1>

    <div>
      <span>Welcome, <%= user.username %></span>
      <a href="/logout" class="btn">Logout</a>
    </div>
  </nav>

  <main class="dashboard">


    <section class="section-box">
      <div class="section-header">
        <div>
          <h2>Latest News</h2>
          <p>Top headlines from OKSurf API.</p>
        </div>

        <div class="search-box">
          <input type="text" id="newsSearch" placeholder="Search news...">
          <button onclick="loadNews()">Search News</button>
        </div>
      </div>

      <div id="newsContainer" class="cards">
        <p>Loading news...</p>
      </div>
    </section>


 
    <section class="section-box">
      <div class="section-header">
        <div>
          <h2>Weather Report</h2>
          <p>Showing Lagos weather by default. Search any city below.</p>
        </div>
      </div>


        <div class="weather-dashboard">
          <h2>Weather Dashboard</h2>

          <form id="weatherForm">
            <input type="text" id="cityInput" placeholder="Search City..." />
            <button>Search</button>
          </form>

          <div class="weather-grid">
            <section class="main-weather-card">
              <h3 id="cityName">Forecast in Lagos</h3>
              <h1 id="temperature">29°C</h1>
              <p id="condition">Cloudy</p>
              <p id="highLow">High 31°C / Low 25°C</p>
            </section>

            <section class="weather-details">
              <p>Visibility: <span id="visibility"></span></p>
              <p>Humidity: <span id="humidity"></span></p>
              <p>Wind: <span id="wind"></span></p>
            </section>

            <section class="sun-card">
              <p>Sunrise: <span id="sunrise"></span></p>
              <p>Sunset: <span id="sunset"></span></p>
            </section>
          </div>

          <div id="forecastCards" class="forecast-row"></div>
        </div>

    </section>
  </main>


  <script>
  setTimeout(() => {
    const toast = document.querySelector(".toast");

    if (toast) {
      toast.style.opacity = "0";
      toast.style.transform = "translateX(100%)";

      setTimeout(() => {
        toast.remove();
      }, 300);
    }
  }, 3000);
</script>



<script src="/js/index.js"></script>
</body>
</html>

