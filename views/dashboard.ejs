<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <% if (success?.length) { %>
    <div class="toast success"><%= success[0] %></div>
  <% } %>

  <% if (error?.length) { %>
    <div class="toast error"><%= error[0] %></div>
  <% } %>

  <nav class="navbar">
    <h1>Dashboard</h1>

    <div>
      <span>Welcome, <%= user.username %></span>
      <a href="/logout" class="btn">Logout</a>
    </div>
  </nav>

  <main class="dashboard">


    <section class="section-box">
      <div class="section-header">
        <div>
          <h2>Latest News</h2>
          <p>Top headlines from OKSurf API.</p>
        </div>

        <div class="search-box">
          <input type="text" id="newsSearch" placeholder="Search news...">
          <button onclick="loadNews()">Search News</button>
        </div>
      </div>

      <div id="newsContainer" class="cards">
        <p>Loading news...</p>
      </div>
    </section>

    

 
    <section class="section-box">
      <div class="section-header">
        <div>
          <h2>Weather Report</h2>
          <p>Showing Lagos weather by default. Search any city below.</p>
        </div>
      </div>

      <div class="search-box">
        <input type="text" id="weatherSearch" placeholder="Enter city e.g Abuja, London">
        <button onclick="loadWeather()">Search Weather</button>
      </div>

      <div id="weatherContainer">
        <p>Loading weather...</p>
      </div>
    </section>

  </main>



<script src="/js/index.js"></script>
</body>
</html>










